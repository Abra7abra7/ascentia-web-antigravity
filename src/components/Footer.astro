---
// src/components/Footer.astro
import WithdrawalModal from './WithdrawalModal.astro';
---
<footer class="w-full border-t border-zinc-800 bg-zinc-950 py-12 text-zinc-400">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-8 border-b border-zinc-900">
      <!-- Brand & Info -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <img src="/logo.svg" alt="Ascentia Logo" class="h-6 w-6" />
          <span class="font-black tracking-tighter text-zinc-50 font-sans">
            ASCENTIA
          </span>
        </div>
        <p class="text-xs text-zinc-500 leading-relaxed max-w-sm">
          ASCENTIA s. r. o., Klincová 37/B, Bratislava 821 08<br />
          IČO: 51 858 959 | DIČ: 2120813959<br />
          Zapísaná v OR OS Bratislava I, Oddiel: Sro, Vložka č.: 130325/B
        </p>
        <p class="text-xs text-zinc-400 font-medium">
          Kontakt: <a href="mailto:info@ascentia.academy" class="text-violet-400 hover:underline">info@ascentia.academy</a>
        </p>
      </div>

      <!-- Quick links -->
      <div class="flex flex-col gap-3 text-sm">
        <span class="text-xs font-bold text-zinc-300 uppercase tracking-widest">Odkazy</span>
        <a href="/" class="hover:text-zinc-50 transition-colors w-max">Domov</a>
        <a href="/vop" class="hover:text-zinc-50 transition-colors w-max">Všeobecné obchodné podmienky</a>
        <a href="/gdpr" class="hover:text-zinc-50 transition-colors w-max">Ochrana osobných údajov</a>
        <!-- EU 2026 Online Contract Withdrawal Trigger -->
        <button
          id="btn-withdrawal-trigger"
          class="text-zinc-400 hover:text-red-400 transition-colors cursor-pointer text-sm font-medium focus:outline-none w-max text-left"
        >
          Odstúpiť od zmluvy online
        </button>
      </div>

      <!-- Newsletter / Socials -->
      <div class="space-y-4">
        <span class="text-xs font-bold text-zinc-300 uppercase tracking-widest">Newsletter a novinky</span>
        <form class="flex gap-2" onsubmit="event.preventDefault(); alert('Odber úspešne prihlásený!');">
          <input 
            type="email" 
            placeholder="Tvoj e-mail" 
            required
            class="rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2 text-xs text-zinc-100 placeholder-zinc-650 focus:border-violet-500 focus:outline-none w-full"
          />
          <button 
            type="submit" 
            class="bg-violet-600 hover:bg-violet-750 text-zinc-50 text-xs font-bold px-4 py-2 rounded-lg transition-colors cursor-pointer shrink-0"
          >
            Prihlásiť
          </button>
        </form>
        <div class="flex items-center gap-4 text-zinc-500">
          <span class="text-xs">Sledujte nás:</span>
          <!-- Mock Social Icons -->
          <a href="#" class="hover:text-violet-400 transition-colors font-bold text-xs">LinkedIn</a>
          <a href="#" class="hover:text-violet-400 transition-colors font-bold text-xs">GitHub</a>
          <a href="#" class="hover:text-violet-400 transition-colors font-bold text-xs">YouTube</a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-between gap-4 pt-8 text-xs text-zinc-500">
      <p>&copy; 2026 Ascentia. Všetky práva vyhradené. AI-First & Jamstack platforma.</p>
      <p class="flex gap-2">
        <span>Legislatívna zhoda EÚ 2026</span>
        <span class="text-emerald-500">&#x25CF; Kompatibilné</span>
      </p>
    </div>
  </div>

  <!-- Modal window for withdrawal -->
  <WithdrawalModal />
</footer>

<script>
  // Script to open modal
  const triggerBtn = document.getElementById('btn-withdrawal-trigger');
  const modal = document.getElementById('withdrawal-modal');

  if (triggerBtn && modal) {
    triggerBtn.addEventListener('click', () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden'; // Lock scrolling
    });
  }
</script>
