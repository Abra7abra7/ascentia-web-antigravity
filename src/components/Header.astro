---
// src/components/Header.astro
const purchasedCourse = Astro.cookies.get('ascentia_purchased_course')?.value;
---
<header class="sticky top-0 z-50 w-full border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl h-16 items-center justify-between px-6 md:px-8">
    <a href="/" class="flex items-center gap-3 transition-transform hover:scale-102">
      <img src="/logo.svg" alt="Ascentia Logo" class="h-8 w-8" />
      <span class="font-black text-2xl tracking-tighter text-zinc-50 font-sans">
        ASCENTIA
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-zinc-400">
      <a href="/" class="transition-colors hover:text-zinc-50">Domov</a>
      {purchasedCourse ? (
        <a href={`/nakupe-uspesny?course=${encodeURIComponent(purchasedCourse)}`} class="transition-colors text-emerald-400 hover:text-emerald-300">Môj Kurz</a>
      ) : (
        <a href="/#onboarding" class="transition-colors hover:text-zinc-50">AI Sprievodca</a>
      )}
      <a href="/vop" class="transition-colors hover:text-zinc-50">Obchodné podmienky</a>
      <a href="/gdpr" class="transition-colors hover:text-zinc-50">GDPR</a>
    </nav>

    <div class="flex items-center gap-4">
      {purchasedCourse ? (
        <a
          href={`/nakupe-uspesny?course=${encodeURIComponent(purchasedCourse)}`}
          class="relative inline-flex items-center justify-center rounded-xl bg-emerald-600 px-4 py-2 text-xs font-bold text-zinc-50 transition-all hover:bg-emerald-700 hover:shadow-[0_0_20px_rgba(16,185,129,0.4)]"
        >
          Odomknutý Kurz
        </a>
      ) : (
        <a
          href="/#onboarding"
          class="relative inline-flex items-center justify-center rounded-xl bg-violet-600 px-4 py-2 text-xs font-bold text-zinc-50 transition-all hover:bg-violet-700 hover:shadow-[0_0_20px_rgba(124,58,237,0.4)]"
        >
          Spustiť vzostup
        </a>
      )}
    </div>
  </div>
</header>

