---
// src/pages/nakupe-uspesny.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// We extract the URL search param or fallback to a default course name
const courseTitle = Astro.url.searchParams.get('course') || "Prémiový Kurz Ascentia";
const whatsappSupportNumber = import.meta.env.PUBLIC_WHATSAPP_SUPPORT_NUMBER || import.meta.env.WHATSAPP_SUPPORT_NUMBER || process.env.WHATSAPP_SUPPORT_NUMBER || "421944123456";

// Set a cookie so the homepage knows the user purchased this course
Astro.cookies.set('ascentia_purchased_course', courseTitle, {
  path: '/',
  maxAge: 60 * 60 * 24 * 365, // 1 year
  httpOnly: false,
});
---

<Layout title="Nákup úspešný - Ascentia" description="Váš prístup k prémiovému vzdelávaniu bol úspešne odomknutý.">
  <Header />

  <main class="flex-grow py-16 bg-zinc-950">
    <div class="mx-auto max-w-4xl px-6 md:px-8">
      
      <!-- Success Banner -->
      <div class="rounded-2xl border border-emerald-500/20 bg-emerald-950/10 p-8 text-center mb-12">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-500/10 border border-emerald-500 text-emerald-400 mb-4 animate-bounce">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="text-3xl md:text-4xl font-black text-zinc-50 tracking-tight mb-2">Platba prebehla úspešne!</h1>
        <p class="text-emerald-400 font-bold text-sm tracking-wider uppercase mb-4">Prístup bol údomknutý</p>
        <div class="h-[1px] bg-zinc-800 my-4 max-w-xs mx-auto"></div>
        <p class="text-zinc-400 text-sm max-w-md mx-auto">
          Práve ste získali doživotný prístup k vzdelávaciemu modulu: <br />
          <strong class="text-zinc-200">{courseTitle}</strong>.
        </p>
      </div>

      <!-- Course Workspace / Video Lesson -->
      <div class="rounded-2xl border border-zinc-800 bg-zinc-900 overflow-hidden shadow-2xl">
        <!-- Video Placeholder Header -->
        <div class="border-b border-zinc-800 bg-zinc-950 px-6 py-4 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="flex h-2.5 w-2.5 rounded-full bg-emerald-500"></span>
            <span class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Odomknutá lekcia 01</span>
          </div>
          <span class="text-xs text-zinc-500">Dĺžka: 45 min</span>
        </div>

        <!-- Simulated Premium Video Player -->
        <div class="relative aspect-video w-full bg-zinc-950 flex items-center justify-center group cursor-pointer">
          <img src="/course-thumb.svg" alt="Video cover" class="absolute inset-0 w-full h-full object-cover opacity-60 transition-opacity group-hover:opacity-40" />
          
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/90 to-transparent"></div>

          <!-- Video Play interface overlay -->
          <div class="relative z-10 text-center">
            <button class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-violet-600 border border-violet-500 text-zinc-50 transition-transform duration-300 hover:scale-105 hover:bg-violet-700 hover:shadow-[0_0_30px_rgba(124,58,237,0.6)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 ml-1.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </button>
            <p class="text-xs font-bold text-zinc-300 uppercase tracking-widest mt-4">Prehrať úvodné video</p>
          </div>
        </div>

        <!-- Course Resources -->
        <div class="p-6 md:p-8 space-y-6">
          <div>
            <h2 class="text-xl font-bold text-zinc-100 mb-2">Ďalšie kroky pre Váš rozvoj</h2>
            <p class="text-zinc-400 text-sm leading-relaxed">
              Váš prístup k plnej platforme s diskusným fórom bol taktiež odoslaný na zadaný e-mail. Skontrolujte si aj priečinok so spamom, ak správa nedorazí do 5 minút.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-zinc-800">
            <div class="p-4 rounded-xl bg-zinc-950 border border-zinc-800">
              <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest block mb-1">WhatsApp Podpora</span>
              <p class="text-sm text-zinc-300 mb-3">Pripojte sa k našej interaktívnej komunite priamo vo Vašom telefóne.</p>
              <a href={`https://wa.me/${whatsappSupportNumber}`} target="_blank" class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-zinc-50 font-bold px-4 py-2 text-xs transition-colors">
                Pripojiť sa na WhatsApp
              </a>
            </div>
            <div class="p-4 rounded-xl bg-zinc-950 border border-zinc-800">
              <span class="text-xs font-bold text-zinc-500 uppercase tracking-widest block mb-1">Materiály na stiahnutie</span>
              <p class="text-sm text-zinc-300 mb-3">Stiahnite si e-knihu a schému pre integráciu AI agentov.</p>
              <a href="/materialy-ascentia.pdf" download class="inline-flex items-center gap-2 rounded-lg bg-zinc-800 hover:bg-zinc-700 text-zinc-200 font-bold px-4 py-2 text-xs transition-colors">
                Stiahnuť PDF (5.2 MB)
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>
