---
// src/pages/blog/index.astro
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import posts from '../../data/posts.json';

export const prerender = false;
---

<Layout 
  title="Blog - Ascentia Tech Hub" 
  description="Novinky, návody a inšpirácie z oblasti umelej inteligencie, autonómnych agentov a moderného webového vývoja."
>
  <Header />

  <main class="flex-grow py-16 md:py-24 relative overflow-hidden bg-zinc-950">
    <!-- Glow Backgrounds -->
    <div class="absolute top-10 left-1/4 -z-10 h-[500px] w-[500px] rounded-full bg-violet-900/10 blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-20 right-1/4 -z-10 h-[400px] w-[400px] rounded-full bg-emerald-950/10 blur-[100px] pointer-events-none"></div>

    <div class="mx-auto max-w-7xl px-6 md:px-8">
      <!-- Header block -->
      <div class="text-center max-w-3xl mx-auto mb-16">
        <div class="inline-flex items-center gap-2 rounded-full border border-violet-500/30 bg-violet-950/20 px-3 py-1 text-xs font-bold text-violet-400 mb-6">
          <span class="flex h-2 w-2 rounded-full bg-violet-400 animate-pulse"></span>
          Ascentia Tech Hub & Blog
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-zinc-50 tracking-tight mb-6">
          Náš technologický <span class="bg-gradient-to-r from-violet-400 to-violet-600 bg-clip-text text-transparent">blog</span>
        </h1>
        <p class="text-zinc-400 text-base md:text-lg leading-relaxed">
          Články a tutoriály o AI agentoch, low-code automatizáciách a vývoji softvéru, písané a aktualizované naším AI autopilotom.
        </p>
      </div>

      <!-- Blog post grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        {posts.map((post) => (
          <article class="rounded-2xl border border-zinc-850 bg-zinc-900/30 overflow-hidden flex flex-col justify-between hover:border-violet-500/30 transition-all duration-300 group hover:shadow-2xl hover:shadow-violet-950/10">
            {post.image && (
              <div class="relative overflow-hidden aspect-[21/9] md:aspect-[16/9] border-b border-zinc-850">
                <img 
                  src={post.image} 
                  alt={post.title} 
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-103"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/60 to-transparent"></div>
              </div>
            )}
            <div class="p-6 md:p-8 flex-grow flex flex-col justify-between">
              <div>
                <div class="flex items-center gap-3 text-xs text-zinc-500 mb-4">
                  <span>{post.date}</span>
                  <span>•</span>
                  <span>{post.readTime}</span>
                  <span>•</span>
                  <span class="text-violet-400 font-bold">{post.author}</span>
                </div>
                <h2 class="text-xl md:text-2xl font-black text-zinc-100 group-hover:text-violet-400 transition-colors mb-3 leading-tight">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                <p class="text-zinc-400 text-sm leading-relaxed mb-6">
                  {post.excerpt}
                </p>
              </div>
              
              <a 
                href={`/blog/${post.slug}`} 
                class="inline-flex items-center gap-2 text-sm font-bold text-zinc-50 group-hover:text-violet-400 transition-colors mt-auto w-max"
              >
                Čítať viac <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
