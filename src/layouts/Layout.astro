---
// src/layouts/Layout.astro
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.svelte';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ascentia - AI-First & Jamstack Platforma pre Prémiové Vzdelávanie",
  description = "Prémiové kurzy zamerané na AI automatizáciu a pokročilý vývoj v roku 2026."
} = Astro.props;
---
<!doctype html>
<html lang="sk" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="canonical" href={new URL(Astro.url.pathname, "https://ascentia-web-antigravity.vercel.app").href} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, "https://ascentia-web-antigravity.vercel.app").href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://ascentia-web-antigravity.vercel.app/og-image.png" />
    <meta property="og:locale" content="sk_SK" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={new URL(Astro.url.pathname, "https://ascentia-web-antigravity.vercel.app").href} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://ascentia-web-antigravity.vercel.app/og-image.png" />
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;950&family=Outfit:wght@700;900&display=swap" rel="stylesheet">
    
    <!-- Schema.org Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Ascentia",
        "url": "https://ascentia-web-antigravity.vercel.app/",
        "description": "AI-First & Jamstack platforma pre prémiové technologické vzdelávanie.",
        "publisher": {
          "@type": "Organization",
          "name": "ASCENTIA s. r. o.",
          "logo": {
            "@type": "ImageObject",
            "url": "https://ascentia-web-antigravity.vercel.app/logo.svg"
          }
        }
      }
    </script>
    
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-[#09090B] text-zinc-400 font-sans min-h-screen flex flex-col antialiased selection:bg-violet-600 selection:text-white">
    <slot />
    <CookieBanner client:load />
  </body>
</html>

<style is:global>
  :root {
    --font-heading: 'Outfit', 'Geist Sans', system-ui, -apple-system, sans-serif;
    --font-body: 'Inter', system-ui, -apple-system, sans-serif;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }
  
  body {
    font-family: var(--font-body);
  }
</style>
